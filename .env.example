DEVDOCS_APP_NAME="DevDocs Binance Spot Agent"
DEVDOCS_APP_VERSION="0.1.0"
DEVDOCS_APP_ENV="local"
DEVDOCS_DEBUG="false"
DEVDOCS_LOG_LEVEL="INFO"

DEVDOCS_MODEL_PROVIDER="openai-compatible"
DEVDOCS_MODEL_NAME="gpt-4.1-mini"
DEVDOCS_MODEL_BASE_URL="https://api.openai.com/v1"
DEVDOCS_MODEL_API_KEY="replace-me"

DEVDOCS_DATABASE_URL="sqlite:///./devdocs.db"
DEVDOCS_ENABLE_WEB_SEARCH="false"
DEVDOCS_WEB_SEARCH_PROVIDER="duckduckgo"
DEVDOCS_WEB_SEARCH_BASE_URL="https://api.duckduckgo.com"
DEVDOCS_WEB_SEARCH_TIMEOUT_S="10"
DEVDOCS_ENABLE_WEB_FETCH="true"
DEVDOCS_WEB_FETCH_TIMEOUT_S="15"
DEVDOCS_WEB_FETCH_MAX_CHARS="4000"
